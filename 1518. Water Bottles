class Solution:
    def numWaterBottles(numBottles, numExchange):
        check_bottles = numBottles
        count = 0
        while True:
            count = count + check_bottles
            check_bottles = int(numBottles/numExchange)
            numBottles = numBottles - check_bottles*numExchange + check_bottles
            if check_bottles == 0:
                break
        return count
